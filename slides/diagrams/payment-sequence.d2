direction: right

request: {
  style.fill: "#e8f0fe"
  style.stroke: "#0066ff"
  style.border-radius: 10

  label: "1. REQUEST"
  icon: ""
  desc: "Agent calls\npremium_random()\nvia MCP client" {
    style.fill: "#f0f8ff"
    style.stroke: "#0066ff"
    style.border-radius: 8
  }
}

challenge: {
  style.fill: "#fff0e0"
  style.stroke: "#ff6600"
  style.border-radius: 10

  label: "2. CHALLENGE"
  desc: "Server returns\n402 Payment Required\n+ price requirements" {
    style.fill: "#fff8f0"
    style.stroke: "#ff6600"
    style.border-radius: 8
  }
}

sign: {
  style.fill: "#fffbeb"
  style.stroke: "#ffc107"
  style.border-radius: 10

  label: "3. SIGN"
  desc: "withPayment() signs\nEIP-3009 authorization\n(off-chain, gasless)" {
    style.fill: "#fffff0"
    style.stroke: "#ffc107"
    style.border-radius: 8
  }
}

retry: {
  style.fill: "#f0fff0"
  style.stroke: "#28a745"
  style.border-radius: 10

  label: "4. RETRY"
  desc: "Request retries\nwith Payment header\nautomatically" {
    style.fill: "#f5fff5"
    style.stroke: "#28a745"
    style.border-radius: 8
  }
}

settle: {
  style.fill: "#0066ff"
  style.stroke: "#0044aa"
  style.border-radius: 10
  style.font-color: "#ffffff"

  label: "5. SETTLE"
  desc: "Facilitator verifies\nand settles USDC\non Base network" {
    style.fill: "#3388ff"
    style.stroke: "#0044aa"
    style.border-radius: 8
    style.font-color: "#ffffff"
  }
}

request -> challenge: "402" {
  style.stroke: "#ff6600"
  style.stroke-width: 3
}
challenge -> sign: "intercept" {
  style.stroke: "#ffc107"
  style.stroke-width: 3
}
sign -> retry: "+ header" {
  style.stroke: "#28a745"
  style.stroke-width: 3
}
retry -> settle: "on-chain" {
  style.stroke: "#0066ff"
  style.stroke-width: 3
}
