direction: right

user: User {
  shape: person
  style.fill: "#e8f0fe"
  style.stroke: "#0066ff"
}

agent: "ToolLoopAgent\n(max 10 steps)" {
  style.fill: "#0066ff"
  style.font-color: "#ffffff"
  style.stroke: "#0044aa"
  style.border-radius: 8
  style.bold: true
}

tools: Tool Registry {
  direction: down
  style.fill: "#f8f9fa"
  style.stroke: "#aaaaaa"
  style.border-radius: 10

  row1: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    mcp: MCP Tools {
      style.fill: "#e8f0fe"
      style.stroke: "#0066ff"
      style.border-radius: 8
    }
    budget: Budget {
      style.fill: "#d4edda"
      style.stroke: "#28a745"
      style.border-radius: 8
    }
  }
  row2: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    discovery: Discovery {
      style.fill: "#e8f0fe"
      style.stroke: "#0066ff"
      style.border-radius: 8
    }
    local: Local {
      style.fill: "#e8f0fe"
      style.stroke: "#0066ff"
      style.border-radius: 8
    }
  }
}

server: "/mcp Server" {
  direction: down
  style.fill: "#f0f4ff"
  style.stroke: "#0066ff"
  style.border-radius: 8

  free: "Free Tools" {
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    style.border-radius: 8
  }
  paid: "Paid Tools" {
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    style.border-radius: 8
  }
}

payment: Payment Flow {
  direction: down
  style.fill: "#fff8f0"
  style.stroke: "#ff6600"
  style.border-radius: 10

  four02: "402 Required" {
    style.fill: "#ffe0cc"
    style.stroke: "#ff6600"
    style.border-radius: 8
  }
  wp: "withPayment()\nEIP-3009 sign" {
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    style.border-radius: 8
  }
  settle: "Facilitator\n-> Base USDC" {
    style.fill: "#0066ff"
    style.font-color: "#ffffff"
    style.stroke: "#0044aa"
    style.border-radius: 8
  }

  four02 -> wp: intercept
  wp -> settle: "retry +\nPayment header"
}

# Main flow
user -> agent: "Chat UI\n/api/chat" {style.stroke: "#666666"}
agent -> tools {style.stroke: "#0066ff"}
tools.row1.mcp -> server {style.stroke: "#0066ff"}
server.paid -> payment.four02 {style.stroke: "#ff6600"}
