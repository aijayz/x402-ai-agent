# This is an example env file
# Copy it to `.env.local` and set your secrets

# ===========================================
# CDP Configuration (required for payment operations)
# ===========================================
# https://docs.cdp.coinbase.com/api-reference/v2/authentication
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# ===========================================
# AI Provider Configuration
# ===========================================
# Google Gemini (default model -- free tier available at https://aistudio.google.com/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=

# DeepSeek (backup/reasoning model)
DEEPSEEK_API_KEY=

# AI model ID (format: provider/model)
# Available models:
#   google/gemini-2.0-flash      -- fast, free tier
#   google/gemini-2.5-flash      -- smarter, free tier
#   deepseek/deepseek-chat       -- default fallback
#   deepseek/deepseek-reasoner   -- reasoning model (shows chain-of-thought)
AI_MODEL=google/gemini-2.5-flash

# ===========================================
# Network Configuration
# ===========================================
NETWORK=base-sepolia  # Options: base-sepolia, base
NEXT_PUBLIC_NETWORK=base-sepolia  # Same as NETWORK -- exposed to client for wallet chain switching
URL=http://localhost:3000

# ===========================================
# Neon Postgres (required for credit system)
# ===========================================
DATABASE_URL=postgresql://...

# ===========================================
# Upstash Redis (optional -- used for rate limiting)
# ===========================================
# Create a free database at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===========================================
# x402 Service URLs (optional)
# ===========================================
# Only needed on mainnet (NETWORK=base). On base-sepolia, stubs are used automatically.
#
# x402 ecosystem services (see https://x402.org/ecosystem):
RUGMUNCH_URL=https://cryptorugmunch.app
AUGUR_URL=https://augurrisk.com
DIAMONDCLAWS_URL=https://diamondclaws.io
GENVOX_URL=https://api.genvox.io
#
# SLAMai — smart money intelligence, wallet trades, token holder reputation ($0.001/call)
SLAMAI_URL=https://api.slamai.dev
#
# QuantumShield — blockchain security intelligence ($0.001-$0.003/call)
# Endpoints: token/security, contract/audit, wallet/risk, whale/activity
QUANTUM_SHIELD_URL=https://quantumshield-api.vercel.app
#
# ===========================================
# Data Provider URLs (optional — defaults used if not set)
# ===========================================
# Messari — institutional crypto intelligence (free endpoint, token unlock schedules)
MESSARI_URL=https://api.messari.io
#
# CoinGecko — token price, search, contract-to-symbol resolution (free tier)
COINGECKO_URL=https://api.coingecko.com/api/v3

# ===========================================
# Cron & Webhooks (optional)
# ===========================================
CRON_SECRET=
ALCHEMY_WEBHOOK_SIGNING_KEY=

# ===========================================
# Build-time Options
# ===========================================
# Set to "true" to skip env validation during build (useful for CI without full env)
# SKIP_ENV_VALIDATION=true
