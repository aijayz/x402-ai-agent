# This is an example env file
# Copy it to `.env.local` and set your secrets

# ===========================================
# Self-Managed Wallet Configuration (Recommended)
# ===========================================

# EVM Wallet (self-managed private key with 0x prefix)
EVM_PRIVATE_KEY=0xyour_evm_private_key_here
EVM_NETWORK=base-sepolia  # Options: base-sepolia, base, ethereum

# Solana Wallet (self-managed private key in base58 format)
SVM_PRIVATE_KEY=your_base58_private_key_here
SOLANA_NETWORK=devnet  # Options: devnet, mainnet

# ===========================================
# CDP Configuration (Optional - for backwards compatibility)
# ===========================================
# https://docs.cdp.coinbase.com/api-reference/v2/authentication
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# ===========================================
# AI Provider Configuration
# ===========================================
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# ===========================================
# Network Configuration
# ===========================================
NETWORK=base-sepolia  # Options: base-sepolia, base
URL=http://localhost:3000