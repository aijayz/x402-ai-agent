# This is an example env file
# Copy it to `.env.local` and set your secrets

# ===========================================
# CDP Configuration (required for payment operations)
# ===========================================
# https://docs.cdp.coinbase.com/api-reference/v2/authentication
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# ===========================================
# AI Provider Configuration
# ===========================================
# On Vercel: run `vercel link` + enable AI Gateway + `vercel env pull`
# to provision VERCEL_OIDC_TOKEN — no API keys needed.
#
# Local dev (without AI Gateway): set DEEPSEEK_API_KEY directly.
DEEPSEEK_API_KEY=

# AI model IDs (gateway format: provider/model)
# These default to deepseek/deepseek-chat and deepseek/deepseek-reasoner
# Override here to route through a different provider via AI Gateway.
AI_MODEL=deepseek/deepseek-chat
AI_REASONING_MODEL=deepseek/deepseek-reasoner

# ===========================================
# Network Configuration
# ===========================================
NETWORK=base-sepolia  # Options: base-sepolia, base
URL=http://localhost:3000
